<%- include('./partials/head') %>
<%- include('./partials/nav') %>

<div class="auth-wrap">
  <div class="auth-card fade-in">
    <h1 class="auth-title">Create your account</h1>
    <p class="auth-sub">Join Blogify and start publishing in minutes.</p>

    <% if (locals.error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form action="/user/signup" method="POST" enctype="multipart/form-data">
      <div class="field">
        <label class="label" for="fullName">Full name</label>
        <input class="input" type="text" id="fullName" name="fullName" placeholder="Ada Lovelace" required />
      </div>
      <div class="field">
        <label class="label" for="email">Email</label>
        <input class="input" type="email" id="email" name="email" placeholder="you@domain.com" required />
      </div>
      <div class="field">
        <label class="label" for="password">Password</label>
        <input class="input" type="password" id="password" name="password" placeholder="At least 6 characters" required />
      </div>
      <div class="field">
        <label class="label" for="profileImage">Profile picture (optional)</label>
        <input class="file-input" type="file" id="profileImage" name="profileImage" accept="image/*" />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Create Account</button>
    </form>

    <p class="auth-foot">Already a member? <a href="/user/signin">Sign in</a></p>
  </div>
</div>

<%- include('./partials/scripts') %>
