<%- include('./partials/head') %>
<%- include('./partials/nav') %>

<section class="hero container">
  <h1>Where ideas <span class="grad">come alive</span>.</h1>
  <p>A modern home for thoughtful writing — discover stories, share your voice, and build your audience on Blogify.</p>
</section>

<main class="container">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
    <form action="/" method="GET" style="display: flex; gap: 8px; flex: 1; min-width: 280px; max-width: 400px; margin: 0;">
      <input type="text" name="search" class="input" placeholder="Search blog titles..." value="<%= locals.searchQuery || '' %>" style="flex: 1;" />
      <button type="submit" class="btn btn-primary">Search</button>
      <% if (locals.searchQuery) { %>
        <a href="/" class="btn" style="padding: 0 12px; display: flex; align-items: center; text-decoration: none;">✕</a>
      <% } %>
    </form>
    <div style="background: var(--surface); padding: 4px; border-radius: 8px; border: 1px solid var(--border); display: inline-flex; gap: 4px;">
      <a href="/?sort=recent<%= locals.searchQuery ? '&search=' + searchQuery : '' %>" class="btn btn-sm" style="<%= currentSort === 'recent' ? 'background: var(--text); color: var(--bg);' : 'background: transparent; color: var(--text-muted); border: none;' %>">Recent</a>
      <a href="/?sort=likes<%= locals.searchQuery ? '&search=' + searchQuery : '' %>" class="btn btn-sm" style="<%= currentSort === 'likes' ? 'background: var(--text); color: var(--bg);' : 'background: transparent; color: var(--text-muted); border: none;' %>">Most Liked</a>
      <a href="/?sort=trending<%= locals.searchQuery ? '&search=' + searchQuery : '' %>" class="btn btn-sm" style="<%= currentSort === 'trending' ? 'background: var(--text); color: var(--bg);' : 'background: transparent; color: var(--text-muted); border: none;' %>">Trending 🔥</a>
    </div>
  </div>
  <div class="grid fade-in-stagger">
    <% blogs.forEach(blog => { %>
      <div class="card" style="position: relative;">
        <a href="/blog/<%= blog._id %>" style="text-decoration:none; color:inherit; display:block;">
          <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" class="card-img" loading="lazy" />
          <div class="card-body">
            <h3 class="card-title"><%= blog.title %></h3>
            <div class="card-foot">
              <div class="author">
                <img src="<%= blog.createdBy.profileImageURL || '/images/default.svg' %>" alt="" class="avatar avatar-sm" />
                <div style="min-width:0;">
                  <div class="author-name"><%= blog.createdBy.fullName %></div>
                  <div class="author-date"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                </div>
              </div>
            </div>
          </div>
        </a>
        <div style="position: absolute; bottom: 20px; right: 20px; z-index: 2; display: flex; align-items: center; gap: 8px;">
          <span style="font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 4px;" title="Views">
            👁️ <%= blog.views || 0 %>
          </span>
          <button type="button" onclick="handleLike(this, '<%= blog._id %>')" style="background: transparent; border: 1px solid var(--border); border-radius: 20px; padding: 4px 12px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-size: 14px; color: var(--text); transition: all 0.2s;">
            <% if (locals.user && blog.likes && blog.likes.includes(user._id)) { %>
              <span class="like-icon" style="color: #ff4757;">❤️</span>
            <% } else { %>
              <span class="like-icon" style="filter: grayscale(100%); opacity: 0.7;">❤️</span>
            <% } %>
            <span class="like-count"><%= blog.likes ? blog.likes.length : 0 %></span>
          </button>
        </div>
      </div>
    <% }) %>
  </div>
  <% if (!blogs || blogs.length === 0) { %>
    <div class="muted-box" style="margin: 40px 0 80px;">
      <% if (locals.searchQuery) { %>
        No blogs found matching "<%= locals.searchQuery %>". <a href="/">Clear search</a>
      <% } else { %>
        No blogs yet. <% if (locals.user) { %><a href="/blog/add-new">Write the first one →</a><% } else { %><a href="/user/signup">Create an account</a> to publish.<% } %>
      <% } %>
    </div>
  <% } %>
</main>

<%- include('./partials/scripts') %>
